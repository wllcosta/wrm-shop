# Cole aqui a connection string do Neon (Dashboard do Neon > Connection Details)
DATABASE_URL=postgresql://usuario:senha@ep-xxxx.us-east-2.aws.neon.tech/venda3d?sslmode=require

# Chave secreta usada para assinar os tokens JWT.
# Gere uma aleatória forte, por exemplo rodando no terminal:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-por-uma-string-aleatoria-bem-grande

# Código combinado entre você e seu irmão, exigido para criar conta em /api/auth/register.
# Depois que os dois criarem as contas, pode remover essa variável (ou trocar o código).
INVITE_CODE=escolha-um-codigo-secreto

PORT=3001
